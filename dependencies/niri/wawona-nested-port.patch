+//! Nested backend: niri as a Wayland client of a host compositor (Wawona).
+//!
+//! Wawona (wwn-niri): on Apple platforms and Android there is no DRM/KMS,
+//! libinput, or winit-Wayland, so niri runs strictly *nested* — it connects to
+//! the host compositor (Wawona) advertised via WAYLAND_DISPLAY, creates one
+//! xdg_toplevel that acts as niri's single output, renders with GLES through
+//! EGL_KHR_platform_wayland (served by wwn-iland/ANGLE on Apple targets), and
+//! translates the host seat's wl_pointer/wl_keyboard/wl_touch events into
+//! niri's input pipeline. niri in turn hosts its own scrollable-tiling clients
+//! on its own (child) Wayland socket.
+//!
+//! Only core + xdg-shell (+ optional xdg-decoration) globals are bound from
+//! the host — exactly the subset Wawona serves.
+
+use std::cell::RefCell;
+use std::collections::HashMap;
+use std::mem;
+use std::os::raw::c_int;
+use std::rc::Rc;
+use std::sync::atomic::{AtomicBool, Ordering};
+use std::sync::{Arc, Mutex};
+
+use anyhow::Context as _;
+use calloop_wayland_source::WaylandSource;
+use niri_config::{Config, OutputName};
+use smithay::backend::allocator::dmabuf::Dmabuf;
+use smithay::backend::allocator::Fourcc;
+use smithay::backend::egl::context::{GlAttributes, PixelFormatRequirements};
+use smithay::backend::egl::display::EGLDisplayHandle;
+use smithay::backend::egl::native::{EGLNativeDisplay, EGLNativeSurface, EGLPlatform};
+use smithay::backend::egl::{ffi, wrap_egl_call_ptr, EGLContext, EGLDisplay, EGLError, EGLSurface};
+use smithay::backend::input::{AxisSource, ButtonState, InputEvent, KeyState};
+use smithay::backend::renderer::damage::OutputDamageTracker;
+use smithay::backend::renderer::gles::{GlesRenderbuffer, GlesRenderer};
+use smithay::backend::renderer::{Bind, DebugFlags, ExportMem, ImportDma, Offscreen, Renderer};
+use smithay::egl_platform;
+use smithay::output::{Mode, Output, PhysicalProperties, Subpixel};
+use smithay::reexports::calloop::LoopHandle;
+use smithay::reexports::wayland_protocols::wp::presentation_time::server::wp_presentation_feedback;
+use smithay::utils::{Physical, Size};
+#[cfg(target_os = "linux")]
+use smithay::wayland::dmabuf::DmabufFeedbackBuilder;
+use smithay::wayland::dmabuf::DmabufGlobal;
+use smithay::wayland::presentation::Refresh;
+use wayland_client::globals::{registry_queue_init, GlobalList, GlobalListContents};
+use wayland_client::protocol::wl_buffer::{self, WlBuffer};
+use wayland_client::protocol::wl_callback::WlCallback;
+use wayland_client::protocol::wl_compositor::WlCompositor;
+use wayland_client::protocol::wl_keyboard::{self, WlKeyboard};
+use wayland_client::protocol::wl_pointer::{self, WlPointer};
+use wayland_client::protocol::wl_registry::WlRegistry;
+use wayland_client::protocol::wl_seat::{self, WlSeat};
+use wayland_client::protocol::wl_shm::{self, WlShm};
+use wayland_client::protocol::wl_shm_pool::WlShmPool;
+use wayland_client::protocol::wl_surface::WlSurface as ClientWlSurface;
+use wayland_client::protocol::wl_touch::{self, WlTouch};
+use wayland_client::{Connection, Dispatch, Proxy, QueueHandle};
+use wayland_egl as wegl;
+use wayland_protocols::xdg::decoration::zv1::client::zxdg_decoration_manager_v1::ZxdgDecorationManagerV1;
+use wayland_protocols::xdg::decoration::zv1::client::zxdg_toplevel_decoration_v1::{
+    self, ZxdgToplevelDecorationV1,
+};
+use wayland_protocols::xdg::shell::client::xdg_surface::{self, XdgSurface};
+use wayland_protocols::xdg::shell::client::xdg_toplevel::{self, XdgToplevel};
+use wayland_protocols::xdg::shell::client::xdg_wm_base::{self, XdgWmBase};
+
+use super::{IpcOutputMap, OutputId, RenderResult};
+use crate::niri::{Niri, RedrawState, State};
+use crate::render_helpers::debug::draw_damage;
+use crate::render_helpers::{resources, shaders, RenderCtx, RenderTarget};
+use crate::utils::{get_monotonic_time, logical_output};
+
+pub mod input;
+pub use input::*;
+
+const DEFAULT_SIZE: (i32, i32) = (1280, 800);
+
+/// EGL native display over the host libwayland client connection.
+struct NestedEglDisplay(*mut std::os::raw::c_void);
+
+// SAFETY: the pointer is the host libwayland wl_display, which outlives the
+// backend and is safe to hand to EGL from any thread.
+unsafe impl Send for NestedEglDisplay {}
+
+impl EGLNativeDisplay for NestedEglDisplay {
+    fn supported_platforms(&self) -> Vec<EGLPlatform<'_>> {
+        let display = self.0;
+        vec![
+            // see: https://www.khronos.org/registry/EGL/extensions/KHR/EGL_KHR_platform_wayland.txt
+            egl_platform!(PLATFORM_WAYLAND_KHR, display, &["EGL_KHR_platform_wayland"]),
+            // see: https://www.khronos.org/registry/EGL/extensions/EXT/EGL_EXT_platform_wayland.txt
+            egl_platform!(PLATFORM_WAYLAND_EXT, display, &["EGL_EXT_platform_wayland"]),
+            // see: https://raw.githubusercontent.com/google/angle/main/extensions/EGL_ANGLE_platform_angle.txt
+            //
+            // Note: ANGLE's Vulkan backend accepts a wl_display native handle
+            // (EGL_PLATFORM_ANGLE_NATIVE_PLATFORM_TYPE_ANGLE = WAYLAND_EXT)
+            // even when EGL_EXT_platform_wayland is not advertised as a
+            // *client* extension, so don't require it here.
+            egl_platform!(
+                PLATFORM_ANGLE_ANGLE,
+                display,
+                &[
+                    "EGL_ANGLE_platform_angle",
+                    "EGL_ANGLE_platform_angle_vulkan",
+                ],
+                vec![
+                    ffi::egl::PLATFORM_ANGLE_NATIVE_PLATFORM_TYPE_ANGLE,
+                    ffi::egl::PLATFORM_WAYLAND_EXT as _,
+                    ffi::egl::PLATFORM_ANGLE_TYPE_ANGLE,
+                    ffi::egl::PLATFORM_ANGLE_TYPE_VULKAN_ANGLE,
+                    ffi::egl::NONE as ffi::EGLint
+                ]
+            ),
+        ]
+    }
+
+    fn identifier(&self) -> Option<String> {
+        Some("nested (host wayland)".to_owned())
+    }
+}
+
+static NESTED_SURFACE_ATTRIBUTES: [c_int; 3] = [
+    ffi::egl::RENDER_BUFFER as c_int,
+    ffi::egl::BACK_BUFFER as c_int,
+    ffi::egl::NONE as c_int,
+];
+
+/// Whether the EGL implementation can create window surfaces from
+/// wl_egl_window (a real Wayland winsys).
+///
+/// ANGLE on Apple targets and Android system EGL initialize a display over
+/// the wl_display handle (Vulkan/Metal backends) but have no Wayland window
+/// surface support — CreatePlatformWindowSurfaceEXT would treat the
+/// wl_egl_window as a native object of the underlying OS (CALayer /
+/// ANativeWindow) and crash. In that case rendering goes through the
+/// offscreen + wl_shm readback path instead.
+///
+/// Must be called after the EGL library has been loaded (EGLDisplay::new).
+fn egl_has_wayland_winsys() -> bool {
+    unsafe {
+        let ptr = ffi::egl::QueryString(ffi::egl::NO_DISPLAY, ffi::egl::EXTENSIONS as ffi::EGLint);
+        if ptr.is_null() {
+            return false;
+        }
+        let extensions = std::ffi::CStr::from_ptr(ptr).to_string_lossy();
+        extensions
+            .split_whitespace()
+            .any(|ext| ext == "EGL_KHR_platform_wayland" || ext == "EGL_EXT_platform_wayland")
+    }
+}
+
+/// EGL native surface over a wl_egl_window for the host surface.
+struct NestedEglSurface(wegl::WlEglSurface);
+
+unsafe impl EGLNativeSurface for NestedEglSurface {
+    unsafe fn create(
+        &self,
+        display: &Arc<EGLDisplayHandle>,
+        config_id: ffi::egl::types::EGLConfig,
+    ) -> Result<*const std::os::raw::c_void, EGLError> {
+        wrap_egl_call_ptr(|| unsafe {
+            ffi::egl::CreatePlatformWindowSurfaceEXT(
+                display.handle,
+                config_id,
+                self.0.ptr() as *mut _,
+                NESTED_SURFACE_ATTRIBUTES.as_ptr(),
+            )
+        })
+    }
+
+    fn resize(&self, width: i32, height: i32, dx: i32, dy: i32) -> bool {
+        wegl::WlEglSurface::resize(&self.0, width, height, dx, dy);
+        true
+    }
+
+    fn identifier(&self) -> Option<String> {
+        Some("nested (wl_egl_window)".to_owned())
+    }
+}
+
+/// How rendered frames reach the host surface.
+enum Present {
+    /// Direct EGL window surface over a wl_egl_window; eglSwapBuffers
+    /// attaches + commits. Used when the host EGL has a Wayland winsys.
+    Egl(EGLSurface),
+    /// Offscreen GLES renderbuffer + CPU readback into wl_shm buffers.
+    /// Used with ANGLE (Apple targets) and Android system EGL, which
+    /// initialize an EGL display but cannot create Wayland window surfaces.
+    Shm(ShmState),
+}
+
+struct ShmState {
+    shm: WlShm,
+    renderbuffer: Option<GlesRenderbuffer>,
+    slots: [Option<ShmSlot>; 2],
+    /// Size the renderbuffer + slots were created for.
+    size: Option<Size<i32, Physical>>,
+}
+
+/// One wl_shm buffer: an unlinked temp file mapped into memory.
+struct ShmSlot {
+    buffer: WlBuffer,
+    pool: WlShmPool,
+    ptr: *mut u8,
+    len: usize,
+    /// Cleared on attach, set again by wl_buffer.release.
+    free: Arc<AtomicBool>,
+}
+
+impl Drop for ShmSlot {
+    fn drop(&mut self) {
+        self.buffer.destroy();
+        self.pool.destroy();
+        unsafe {
+            libc::munmap(self.ptr.cast(), self.len);
+        }
+    }
+}
+
+impl ShmSlot {
+    fn new(
+        shm: &WlShm,
+        qh: &QueueHandle<State>,
+        size: Size<i32, Physical>,
+    ) -> anyhow::Result<Self> {
+        use std::os::fd::{AsFd, AsRawFd, FromRawFd, OwnedFd};
+
+        let stride = size.w * 4;
+        let len = (stride * size.h) as usize;
+
+        // Sandbox-safe backing file: XDG_RUNTIME_DIR lives inside the app
+        // container on Apple/Android targets.
+        let dir = std::env::var_os("XDG_RUNTIME_DIR")
+            .map(std::path::PathBuf::from)
+            .unwrap_or_else(std::env::temp_dir);
+        let template = dir.join("niri-nested-shm-XXXXXX");
+        let mut path = template.into_os_string().as_encoded_bytes().to_vec();
+        path.push(0);
+        let fd = unsafe { libc::mkstemp(path.as_mut_ptr().cast()) };
+        anyhow::ensure!(
+            fd >= 0,
+            "mkstemp failed: {}",
+            std::io::Error::last_os_error()
+        );
+        let fd = unsafe { OwnedFd::from_raw_fd(fd) };
+        unsafe { libc::unlink(path.as_ptr().cast()) };
+        let ret = unsafe { libc::ftruncate(fd.as_raw_fd(), len as libc::off_t) };
+        anyhow::ensure!(
+            ret == 0,
+            "ftruncate failed: {}",
+            std::io::Error::last_os_error()
+        );
+
+        let ptr = unsafe {
+            libc::mmap(
+                std::ptr::null_mut(),
+                len,
+                libc::PROT_READ | libc::PROT_WRITE,
+                libc::MAP_SHARED,
+                fd.as_raw_fd(),
+                0,
+            )
+        };
+        anyhow::ensure!(
+            ptr != libc::MAP_FAILED,
+            "mmap failed: {}",
+            std::io::Error::last_os_error()
+        );
+
+        let free = Arc::new(AtomicBool::new(true));
+        let pool = shm.create_pool(fd.as_fd(), len as i32, qh, ());
+        let buffer = pool.create_buffer(
+            0,
+            size.w,
+            size.h,
+            stride,
+            wl_shm::Format::Argb8888,
+            qh,
+            free.clone(),
+        );
+
+        Ok(Self {
+            buffer,
+            pool,
+            ptr: ptr.cast(),
+            len,
+            free,
+        })
+    }
+}
+
+/// Host-side (client) Wayland objects.
+///
+/// Several of these are never read back, but must be kept alive for the
+/// lifetime of the connection (dropping the Rust proxy does not destroy the
+/// protocol object, but keeping them makes the ownership explicit).
+#[allow(dead_code)]
+struct HostObjects {
+    _compositor: WlCompositor,
+    surface: ClientWlSurface,
+    wm_base: XdgWmBase,
+    xdg_surface: XdgSurface,
+    toplevel: XdgToplevel,
+    _decoration: Option<ZxdgToplevelDecorationV1>,
+    seat: Option<WlSeat>,
+    pointer: Option<WlPointer>,
+    keyboard: Option<WlKeyboard>,
+    touch: Option<WlTouch>,
+}
+
+/// Accumulates a wl_pointer axis frame.
+#[derive(Default)]
+struct PendingAxis {
+    source: Option<AxisSource>,
+    amount: (Option<f64>, Option<f64>),
+    amount_v120: (Option<f64>, Option<f64>),
+    time: u32,
+    has_events: bool,
+}
+
+pub struct Nested {
+    config: Rc<RefCell<Config>>,
+    connection: Connection,
+    qh: QueueHandle<State>,
+    host: HostObjects,
+
+    output: Output,
+    // The EGL display must be kept alive as long as the surface/context.
+    _egl_display: EGLDisplay,
+    present: Present,
+    renderer: GlesRenderer,
+    damage_tracker: OutputDamageTracker,
+    damage_tracking: bool,
+    dmabuf_global: Option<DmabufGlobal>,
+    ipc_outputs: Arc<Mutex<IpcOutputMap>>,
+
+    /// Set after the initial xdg_surface configure; the output is added to
+    /// niri (and rendering starts) only then.
+    configured: bool,
+    /// Size requested by the latest xdg_toplevel configure.
+    pending_size: Option<Size<i32, Physical>>,
+    /// Current surface/output size in physical pixels.
+    window_size: Size<i32, Physical>,
+    /// Size the EGL surface was last resized to.
+    bind_size: Option<Size<i32, Physical>>,
+    /// Whether a frame callback from the host is outstanding.
+    frame_callback_pending: bool,
+
+    /// Pointer state: last known surface-local position.
+    pointer_position: (f64, f64),
+    pending_axis: PendingAxis,
+}
+
+impl Nested {
+    pub fn new(
+        config: Rc<RefCell<Config>>,
+        event_loop: LoopHandle<'static, State>,
+    ) -> anyhow::Result<Self> {
+        let _span = tracy_client::span!("Nested::new");
+
+        let connection =
+            Connection::connect_to_env().context("error connecting to the host compositor")?;
+
+        let (globals, event_queue) = registry_queue_init::<State>(&connection)
+            .context("error initializing the host registry")?;
+        let qh = event_queue.handle();
+
+        let compositor: WlCompositor = globals
+            .bind(&qh, 1..=6, ())
+            .context("host compositor does not serve wl_compositor")?;
+        let wm_base: XdgWmBase = globals
+            .bind(&qh, 1..=6, ())
+            .context("host compositor does not serve xdg_wm_base")?;
+
+        let surface = compositor.create_surface(&qh, ());
+        let xdg_surface = wm_base.get_xdg_surface(&surface, &qh, ());
+        let toplevel = xdg_surface.get_toplevel(&qh, ());
+        toplevel.set_title("niri (nested)".to_owned());
+        toplevel.set_app_id("niri".to_owned());
+
+        // Ask the host for server-side decorations when available; Wawona
+        // draws SSD frames for nested compositors.
+        let decoration = globals
+            .bind::<ZxdgDecorationManagerV1, State, ()>(&qh, 1..=1, ())
+            .ok()
+            .map(|manager| {
+                let deco = manager.get_toplevel_decoration(&toplevel, &qh, ());
+                deco.set_mode(zxdg_toplevel_decoration_v1::Mode::ServerSide);
+                deco
+            });
+
+        let seat = globals.bind::<WlSeat, State, ()>(&qh, 1..=8, ()).ok();
+
+        // Commit the initial (buffer-less) state; the host replies with the
+        // first configure, after which rendering may start.
+        surface.commit();
+        connection
+            .flush()
+            .context("error flushing the initial host commit")?;
+
+        // EGL over the host wayland display (EGL_KHR_platform_wayland; on
+        // Apple targets this resolves to the wwn-iland/ANGLE EGL).
+        let display_ptr = connection.backend().display_ptr() as *mut std::os::raw::c_void;
+        let egl_display = unsafe { EGLDisplay::new(NestedEglDisplay(display_ptr)) }
+            .context("error creating the nested EGL display")?;
+
+        let gl_attributes = GlAttributes {
+            version: (3, 0),
+            profile: None,
+            debug: cfg!(debug_assertions),
+            vsync: false,
+        };
+        let context = EGLContext::new_with_config(
+            &egl_display,
+            gl_attributes,
+            PixelFormatRequirements::_10_bit(),
+        )
+        .or_else(|_| {
+            EGLContext::new_with_config(
+                &egl_display,
+                gl_attributes,
+                PixelFormatRequirements::_8_bit(),
+            )
+        })
+        .context("error creating the nested EGL context")?;
+
+        let present = if egl_has_wayland_winsys() {
+            let wl_egl_surface =
+                wegl::WlEglSurface::new(surface.id(), DEFAULT_SIZE.0, DEFAULT_SIZE.1)
+                    .context("error creating the wl_egl_window")?;
+            let egl_surface = unsafe {
+                EGLSurface::new(
+                    &egl_display,
+                    context
+                        .pixel_format()
+                        .context("EGL context has no pixel format")?,
+                    context.config_id(),
+                    NestedEglSurface(wl_egl_surface),
+                )
+            }
+            .context("error creating the nested EGL surface")?;
+            Present::Egl(egl_surface)
+        } else {
+            // No Wayland winsys in the host EGL (ANGLE on Apple targets,
+            // Android system EGL): render offscreen and present via wl_shm.
+            info!("host EGL has no Wayland winsys; using offscreen + wl_shm presentation");
+            let shm: WlShm = globals
+                .bind(&qh, 1..=1, ())
+                .context("host compositor does not serve wl_shm")?;
+            Present::Shm(ShmState {
+                shm,
+                renderbuffer: None,
+                slots: [None, None],
+                size: None,
+            })
+        };
+
+        let renderer =
+            unsafe { GlesRenderer::new(context) }.context("error creating the GLES renderer")?;
+        let damage_tracking =
+            matches!(present, Present::Egl(_)) && egl_display.supports_damage();
+
+        let output = Output::new(
+            "nested".to_string(),
+            PhysicalProperties {
+                size: (0, 0).into(),
+                subpixel: Subpixel::Unknown,
+                make: "Wawona".into(),
+                model: "Nested".into(),
+                serial_number: "Unknown".into(),
+            },
+        );
+
+        let mode = Mode {
+            size: Size::from(DEFAULT_SIZE),
+            refresh: 60_000,
+        };
+        output.change_current_state(Some(mode), None, None, None);
+        output.set_preferred(mode);
+
+        output.user_data().insert_if_missing(|| OutputName {
+            connector: "nested".to_string(),
+            make: Some("Wawona".to_string()),
+            model: Some("Nested".to_string()),
+            serial: None,
+        });
+
+        let physical_properties = output.physical_properties();
+        let ipc_outputs = Arc::new(Mutex::new(HashMap::from([(
+            OutputId::next(),
+            niri_ipc::Output {
+                name: output.name(),
+                make: physical_properties.make,
+                model: physical_properties.model,
+                serial: None,
+                physical_size: None,
+                modes: vec![niri_ipc::Mode {
+                    width: DEFAULT_SIZE.0 as u16,
+                    height: DEFAULT_SIZE.1 as u16,
+                    refresh_rate: 60_000,
+                    is_preferred: true,
+                }],
+                current_mode: Some(0),
+                is_custom_mode: true,
+                vrr_supported: false,
+                vrr_enabled: false,
+                logical: Some(logical_output(&output)),
+            },
+        )])));
+
+        let damage_tracker = OutputDamageTracker::from_output(&output);
+
+        WaylandSource::new(connection.clone(), event_queue)
+            .insert(event_loop)
+            .map_err(|err| anyhow::anyhow!("error inserting the host Wayland source: {err}"))?;
+
+        // GlobalList is no longer needed; dynamic globals arrive through the
+        // registry Dispatch below.
+        let _: &GlobalList = &globals;
+
+        Ok(Self {
+            config,
+            connection,
+            qh,
+            host: HostObjects {
+                _compositor: compositor,
+                surface,
+                wm_base,
+                xdg_surface,
+                toplevel,
+                _decoration: decoration,
+                seat,
+                pointer: None,
+                keyboard: None,
+                touch: None,
+            },
+            output,
+            _egl_display: egl_display,
+            present,
+            renderer,
+            damage_tracker,
+            damage_tracking,
+            dmabuf_global: None,
+            ipc_outputs,
+            configured: false,
+            pending_size: None,
+            window_size: Size::from(DEFAULT_SIZE),
+            bind_size: None,
+            frame_callback_pending: false,
+            pointer_position: (0.0, 0.0),
+            pending_axis: PendingAxis::default(),
+        })
+    }
+
+    pub fn init(&mut self, niri: &mut Niri) {
+        let renderer = &mut self.renderer;
+        resources::init(renderer);
+        shaders::init(renderer);
+
+        let config = self.config.borrow();
+        if let Some(src) = config.animations.window_resize.custom_shader.as_deref() {
+            shaders::set_custom_resize_program(renderer, Some(src));
+        }
+        if let Some(src) = config.animations.window_close.custom_shader.as_deref() {
+            shaders::set_custom_close_program(renderer, Some(src));
+        }
+        if let Some(src) = config.animations.window_open.custom_shader.as_deref() {
+            shaders::set_custom_open_program(renderer, Some(src));
+        }
+        drop(config);
+
+        niri.update_shaders();
+
+        self.create_dmabuf_global(niri);
+
+        // The output is added on the initial xdg_surface configure, not here:
+        // committing buffers before the initial configure is a protocol error.
+    }
+
+    fn create_dmabuf_global(&mut self, niri: &mut Niri) {
+        let renderer = &mut self.renderer;
+
+        let primary_formats = renderer.dmabuf_formats();
+        if primary_formats.iter().next().is_none() {
+            // No dmabuf support in the host EGL (common on the SHM-first
+            // Wawona mobile targets, where wwn-iland/ANGLE serves EGL);
+            // clients fall back to wl_shm.
+            debug!("nested EGL exposes no dmabuf formats; skipping the dmabuf global");
+            return;
+        }
+
+        // Dmabuf feedback (v4) needs a DRM render node, which only exists on
+        // Linux; elsewhere serve dmabuf v3 with the plain format list.
+        #[cfg(target_os = "linux")]
+        let dmabuf_global = {
+            let default_feedback = || {
+                let display = renderer.egl_context().display();
+                let device = smithay::backend::egl::EGLDevice::device_for_display(display)
+                    .context("error getting EGL device")?;
+                let node = device
+                    .try_get_render_node()
+                    .context("error getting EGL device render node")?
+                    .context("failed to query EGL device render node")?;
+
+                DmabufFeedbackBuilder::new(node.dev_id(), primary_formats.clone())
+                    .build()
+                    .context("error building dmabuf feedback")
+            };
+
+            match default_feedback() {
+                Ok(feedback) => niri
+                    .dmabuf_state
+                    .create_global_with_default_feedback::<State>(&niri.display_handle, &feedback),
+                Err(err) => {
+                    debug!("failed building default dmabuf feedback, falling back to v3: {err:?}");
+                    niri.dmabuf_state
+                        .create_global::<State>(&niri.display_handle, primary_formats)
+                }
+            }
+        };
+        #[cfg(not(target_os = "linux"))]
+        let dmabuf_global = niri
+            .dmabuf_state
+            .create_global::<State>(&niri.display_handle, primary_formats);
+
+        assert!(self.dmabuf_global.replace(dmabuf_global).is_none());
+    }
+
+    pub fn seat_name(&self) -> String {
+        "nested".to_owned()
+    }
+
+    pub fn with_primary_renderer<T>(
+        &mut self,
+        f: impl FnOnce(&mut GlesRenderer) -> T,
+    ) -> Option<T> {
+        Some(f(&mut self.renderer))
+    }
+
+    pub fn render(&mut self, niri: &mut Niri, output: &Output) -> RenderResult {
+        let _span = tracy_client::span!("Nested::render");
+
+        if !self.configured {
+            // The initial configure has not arrived yet; attaching a buffer
+            // now would be a protocol error.
+            let output_state = niri.output_state.get_mut(output).unwrap();
+            output_state.redraw_state = RedrawState::Idle;
+            return RenderResult::Skipped;
+        }
+
+        // Render the elements.
+        let ctx = RenderCtx {
+            renderer: &mut self.renderer,
+            target: RenderTarget::Output,
+            xray: None,
+        };
+        let mut elements = niri.render_to_vec(ctx, output, true);
+
+        // Visualize the damage, if enabled.
+        if niri.debug_draw_damage {
+            let output_state = niri.output_state.get_mut(output).unwrap();
+            draw_damage(&mut output_state.debug_damage_tracker, &mut elements);
+        }
+
+        // Request a frame callback before the commit (performed by
+        // eglSwapBuffers or the explicit shm attach+commit) so the host
+        // paces our redraws.
+        if !self.frame_callback_pending {
+            self.host.surface.frame(&self.qh, ());
+            self.frame_callback_pending = true;
+        }
+
+        let window_size = self.window_size;
+        let (res, presented) = match &mut self.present {
+            Present::Egl(egl_surface) => {
+                // Resize the EGL surface to the current window size before
+                // binding.
+                if Some(window_size) != self.bind_size {
+                    egl_surface.resize(window_size.w, window_size.h, 0, 0);
+                    self.bind_size = Some(window_size);
+                }
+
+                let res = {
+                    let age = if self.damage_tracking {
+                        egl_surface.buffer_age().unwrap_or(0) as usize
+                    } else {
+                        0
+                    };
+                    let mut framebuffer = match self.renderer.bind(egl_surface) {
+                        Ok(fb) => fb,
+                        Err(err) => {
+                            warn!("error binding the nested EGL surface: {err:?}");
+                            let output_state = niri.output_state.get_mut(output).unwrap();
+                            output_state.redraw_state = RedrawState::Idle;
+                            return RenderResult::Skipped;
+                        }
+                    };
+                    self.damage_tracker
+                        .render_output(&mut self.renderer, &mut framebuffer, age, &elements, [0.; 4])
+                        .unwrap()
+                };
+
+                let mut presented = false;
+                if let Some(damage) = res.damage {
+                    if self
+                        .config
+                        .borrow()
+                        .debug
+                        .wait_for_frame_completion_before_queueing
+                    {
+                        let _span = tracy_client::span!("wait for completion");
+                        if let Err(err) = res.sync.wait() {
+                            warn!("error waiting for frame completion: {err:?}");
+                        }
+                    }
+
+                    let mut damage = damage.clone();
+                    if let Err(err) = egl_surface.swap_buffers(Some(&mut damage)) {
+                        warn!("error swapping the nested EGL surface: {err:?}");
+                    }
+                    presented = true;
+                }
+                (res, presented)
+            }
+            Present::Shm(shm_state) => {
+                // (Re)allocate the offscreen renderbuffer and shm slots when
+                // the window size changes.
+                if shm_state.size != Some(window_size) {
+                    let buffer_size =
+                        smithay::utils::Size::from((window_size.w, window_size.h));
+                    match self.renderer.create_buffer(Fourcc::Abgr8888, buffer_size) {
+                        Ok(rb) => shm_state.renderbuffer = Some(rb),
+                        Err(err) => {
+                            warn!("error creating the offscreen renderbuffer: {err:?}");
+                            let output_state = niri.output_state.get_mut(output).unwrap();
+                            output_state.redraw_state = RedrawState::Idle;
+                            return RenderResult::Skipped;
+                        }
+                    }
+                    shm_state.slots = [None, None];
+                    shm_state.size = Some(window_size);
+                }
+
+                // Find a released shm slot to draw into.
+                let mut slot_idx = None;
+                for (i, slot) in shm_state.slots.iter_mut().enumerate() {
+                    match slot {
+                        Some(s) if s.free.load(Ordering::Acquire) => {
+                            slot_idx = Some(i);
+                            break;
+                        }
+                        None => {
+                            match ShmSlot::new(&shm_state.shm, &self.qh, window_size) {
+                                Ok(s) => {
+                                    *slot = Some(s);
+                                    slot_idx = Some(i);
+                                }
+                                Err(err) => {
+                                    warn!("error creating an shm slot: {err:?}");
+                                }
+                            }
+                            break;
+                        }
+                        _ => (),
+                    }
+                }
+                let Some(slot_idx) = slot_idx else {
+                    // Both buffers are still held by the host; skip this
+                    // frame (the pending frame callback re-queues a redraw).
+                    let output_state = niri.output_state.get_mut(output).unwrap();
+                    output_state.redraw_state = RedrawState::Idle;
+                    return RenderResult::Skipped;
+                };
+
+                let renderbuffer = shm_state.renderbuffer.as_mut().unwrap();
+                let (res, mapping) = {
+                    let mut framebuffer = match self.renderer.bind(renderbuffer) {
+                        Ok(fb) => fb,
+                        Err(err) => {
+                            warn!("error binding the offscreen renderbuffer: {err:?}");
+                            let output_state = niri.output_state.get_mut(output).unwrap();
+                            output_state.redraw_state = RedrawState::Idle;
+                            return RenderResult::Skipped;
+                        }
+                    };
+                    let res = self
+                        .damage_tracker
+                        .render_output(&mut self.renderer, &mut framebuffer, 0, &elements, [0.; 4])
+                        .unwrap();
+
+                    let mapping = if res.damage.is_some() {
+                        let region = smithay::utils::Rectangle::from_size(
+                            smithay::utils::Size::from((window_size.w, window_size.h)),
+                        );
+                        // Argb8888 maps to a BGRA read; Wawona's ANGLE
+                        // supports it, but fall back to Abgr8888 (plain
+                        // RGBA, always readable) with a CPU swizzle.
+                        match self
+                            .renderer
+                            .copy_framebuffer(&framebuffer, region, Fourcc::Argb8888)
+                        {
+                            Ok(m) => Some((m, false)),
+                            Err(_) => match self.renderer.copy_framebuffer(
+                                &framebuffer,
+                                region,
+                                Fourcc::Abgr8888,
+                            ) {
+                                Ok(m) => Some((m, true)),
+                                Err(err) => {
+                                    warn!("error copying the offscreen framebuffer: {err:?}");
+                                    None
+                                }
+                            },
+                        }
+                    } else {
+                        None
+                    };
+                    (res, mapping)
+                };
+
+                let mut presented = false;
+                if let Some((mapping, swizzle)) = mapping {
+                    use smithay::backend::renderer::TextureMapping as _;
+                    match self.renderer.map_texture(&mapping) {
+                        Ok(data) => {
+                            let slot = shm_state.slots[slot_idx].as_ref().unwrap();
+                            let stride = (window_size.w * 4) as usize;
+                            let height = window_size.h as usize;
+                            // Smithay renders to offscreen targets with a
+                            // y-inverted projection (so sampled textures come
+                            // out upright), which cancels the bottom-up row
+                            // order of glReadPixels: when the mapping reports
+                            // flipped, the rows are already top-down for
+                            // wl_shm.
+                            let flipped = !mapping.flipped();
+                            let dst = unsafe {
+                                std::slice::from_raw_parts_mut(slot.ptr, slot.len)
+                            };
+                            for y in 0..height {
+                                let src_y = if flipped { height - 1 - y } else { y };
+                                let src_row = &data[src_y * stride..src_y * stride + stride];
+                                let dst_row = &mut dst[y * stride..y * stride + stride];
+                                if swizzle {
+                                    // RGBA -> BGRA (little-endian ARGB)
+                                    for (d, s) in
+                                        dst_row.chunks_exact_mut(4).zip(src_row.chunks_exact(4))
+                                    {
+                                        d[0] = s[2];
+                                        d[1] = s[1];
+                                        d[2] = s[0];
+                                        d[3] = s[3];
+                                    }
+                                } else {
+                                    dst_row.copy_from_slice(src_row);
+                                }
+                            }
+
+                            slot.free.store(false, Ordering::Release);
+                            self.host.surface.attach(Some(&slot.buffer), 0, 0);
+                            self.host
+                                .surface
+                                .damage_buffer(0, 0, window_size.w, window_size.h);
+                            self.host.surface.commit();
+                            presented = true;
+                        }
+                        Err(err) => {
+                            warn!("error mapping the framebuffer copy: {err:?}");
+                        }
+                    }
+                }
+                (res, presented)
+            }
+        };
+
+        niri.update_primary_scanout_output(output, &res.states);
+
+        let rv;
+        if presented {
+            let _ = self.connection.flush();
+
+            let mut presentation_feedbacks = niri.take_presentation_feedbacks(output, &res.states);
+            presentation_feedbacks.presented::<_, smithay::utils::Monotonic>(
+                get_monotonic_time(),
+                Refresh::Unknown,
+                0,
+                wp_presentation_feedback::Kind::empty(),
+            );
+
+            rv = RenderResult::Submitted;
+        } else {
+            rv = RenderResult::NoDamage;
+        }
+
+        let output_state = niri.output_state.get_mut(output).unwrap();
+        match mem::replace(&mut output_state.redraw_state, RedrawState::Idle) {
+            RedrawState::Idle => unreachable!(),
+            RedrawState::Queued => (),
+            RedrawState::WaitingForVBlank { .. } => unreachable!(),
+            RedrawState::WaitingForEstimatedVBlank(_) => unreachable!(),
+            RedrawState::WaitingForEstimatedVBlankAndQueued(_) => unreachable!(),
+        }
+
+        output_state.frame_callback_sequence = output_state.frame_callback_sequence.wrapping_add(1);
+
+        rv
+    }
+
+    pub fn toggle_debug_tint(&mut self) {
+        let renderer = &mut self.renderer;
+        renderer.set_debug_flags(renderer.debug_flags() ^ DebugFlags::TINT);
+    }
+
+    pub fn import_dmabuf(&mut self, dmabuf: &Dmabuf) -> bool {
+        match self.renderer.import_dmabuf(dmabuf, None) {
+            Ok(_texture) => true,
+            Err(err) => {
+                debug!("error importing dmabuf: {err:?}");
+                false
+            }
+        }
+    }
+
+    pub fn ipc_outputs(&self) -> Arc<Mutex<IpcOutputMap>> {
+        self.ipc_outputs.clone()
+    }
+
+    fn apply_configure(state: &mut State) {
+        let nested = state.backend.nested();
+        let size = nested.pending_size.take();
+        let first_configure = !nested.configured;
+        nested.configured = true;
+
+        let mut new_size = None;
+        if let Some(size) = size {
+            if size.w > 0 && size.h > 0 && size != nested.window_size {
+                nested.window_size = size;
+                new_size = Some(size);
+            }
+        }
+
+        let output = nested.output.clone();
+
+        if let Some(size) = new_size {
+            nested.output.change_current_state(
+                Some(Mode {
+                    size,
+                    refresh: 60_000,
+                }),
+                None,
+                None,
+                None,
+            );
+
+            {
+                let mut ipc_outputs = nested.ipc_outputs.lock().unwrap();
+                let ipc_output = ipc_outputs.values_mut().next().unwrap();
+                let mode = &mut ipc_output.modes[0];
+                mode.width = size.w.clamp(0, u16::MAX as i32) as u16;
+                mode.height = size.h.clamp(0, u16::MAX as i32) as u16;
+                if let Some(logical) = ipc_output.logical.as_mut() {
+                    logical.width = size.w as u32;
+                    logical.height = size.h as u32;
+                }
+                state.niri.ipc_outputs_changed = true;
+            }
+        }
+
+        if first_configure {
+            state.niri.add_output(output.clone(), None, false);
+        } else if new_size.is_some() {
+            state.niri.output_resized(&output);
+        }
+
+        state.niri.queue_redraw(&output);
+    }
+}
