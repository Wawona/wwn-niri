diff --git a/src/backend/nested/input.rs b/src/backend/nested/input.rs
new file mode 100644
index 0000000..68d399a
--- /dev/null
+++ b/src/backend/nested/input.rs
@@ -0,0 +1,377 @@
+//! Input backend types for the nested (Wayland client) backend.
+//!
+//! Wawona (wwn-niri): translates wl_pointer / wl_keyboard / wl_touch events
+//! received from the host compositor (Wawona) into smithay `InputBackend`
+//! events that niri's generic input pipeline consumes. Modeled on smithay's
+//! winit input backend.
+
+use std::path::PathBuf;
+
+use smithay::backend::input::{
+    AbsolutePositionEvent, Axis, AxisRelativeDirection, AxisSource, ButtonState, Device,
+    DeviceCapability, Event, InputBackend, KeyState, KeyboardKeyEvent, Keycode, PointerAxisEvent,
+    PointerButtonEvent, PointerMotionAbsoluteEvent, TouchCancelEvent, TouchDownEvent, TouchEvent,
+    TouchMotionEvent, TouchSlot, TouchUpEvent, UnusedEvent,
+};
+
+/// Marker used to define the `InputBackend` types for the nested backend.
+#[derive(Debug)]
+pub struct NestedInput;
+
+/// Virtual input device representing the host seat.
+#[derive(PartialEq, Eq, Hash, Debug)]
+pub struct NestedVirtualDevice;
+
+impl Device for NestedVirtualDevice {
+    fn id(&self) -> String {
+        String::from("nested")
+    }
+
+    fn name(&self) -> String {
+        String::from("nested (host seat) virtual input")
+    }
+
+    fn has_capability(&self, capability: DeviceCapability) -> bool {
+        matches!(
+            capability,
+            DeviceCapability::Keyboard | DeviceCapability::Pointer | DeviceCapability::Touch
+        )
+    }
+
+    fn usb_id(&self) -> Option<(u32, u32)> {
+        None
+    }
+
+    fn syspath(&self) -> Option<PathBuf> {
+        None
+    }
+}
+
+/// Keyboard event from the host wl_keyboard.
+#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
+pub struct NestedKeyboardInputEvent {
+    pub time: u64,
+    /// evdev keycode as delivered by wl_keyboard::key.
+    pub key: u32,
+    pub state: KeyState,
+}
+
+impl Event<NestedInput> for NestedKeyboardInputEvent {
+    fn time(&self) -> u64 {
+        self.time
+    }
+
+    fn device(&self) -> NestedVirtualDevice {
+        NestedVirtualDevice
+    }
+}
+
+impl KeyboardKeyEvent<NestedInput> for NestedKeyboardInputEvent {
+    fn key_code(&self) -> Keycode {
+        // evdev -> XKB keycode offset, same as every other smithay backend.
+        (self.key + 8).into()
+    }
+
+    fn state(&self) -> KeyState {
+        self.state
+    }
+
+    fn count(&self) -> u32 {
+        1
+    }
+}
+
+/// Absolute pointer motion within the nested output.
+#[derive(Debug, Clone, Copy, PartialEq)]
+pub struct NestedPointerMotionEvent {
+    pub time: u64,
+    /// Surface-local position in logical pixels.
+    pub position: (f64, f64),
+    /// Current surface (== output) logical size.
+    pub surface_size: (i32, i32),
+}
+
+impl Event<NestedInput> for NestedPointerMotionEvent {
+    fn time(&self) -> u64 {
+        self.time
+    }
+
+    fn device(&self) -> NestedVirtualDevice {
+        NestedVirtualDevice
+    }
+}
+
+impl PointerMotionAbsoluteEvent<NestedInput> for NestedPointerMotionEvent {}
+impl AbsolutePositionEvent<NestedInput> for NestedPointerMotionEvent {
+    fn x(&self) -> f64 {
+        self.position.0
+    }
+
+    fn y(&self) -> f64 {
+        self.position.1
+    }
+
+    fn x_transformed(&self, width: i32) -> f64 {
+        if self.surface_size.0 <= 0 {
+            return 0.0;
+        }
+        f64::max(self.position.0 * width as f64 / self.surface_size.0 as f64, 0.0)
+    }
+
+    fn y_transformed(&self, height: i32) -> f64 {
+        if self.surface_size.1 <= 0 {
+            return 0.0;
+        }
+        f64::max(self.position.1 * height as f64 / self.surface_size.1 as f64, 0.0)
+    }
+}
+
+/// Pointer button event from the host wl_pointer.
+#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
+pub struct NestedPointerButtonEvent {
+    pub time: u64,
+    /// Raw button code (BTN_*).
+    pub button: u32,
+    pub state: ButtonState,
+}
+
+impl Event<NestedInput> for NestedPointerButtonEvent {
+    fn time(&self) -> u64 {
+        self.time
+    }
+
+    fn device(&self) -> NestedVirtualDevice {
+        NestedVirtualDevice
+    }
+}
+
+impl PointerButtonEvent<NestedInput> for NestedPointerButtonEvent {
+    fn button_code(&self) -> u32 {
+        self.button
+    }
+
+    fn state(&self) -> ButtonState {
+        self.state
+    }
+}
+
+/// Pointer axis (scroll) event from the host wl_pointer.
+#[derive(Debug, Clone, Copy, PartialEq)]
+pub struct NestedPointerAxisEvent {
+    pub time: u64,
+    pub source: AxisSource,
+    /// Continuous scroll amount (logical pixels), per axis.
+    pub amount: (Option<f64>, Option<f64>),
+    /// v120 discrete scroll amount, per axis.
+    pub amount_v120: (Option<f64>, Option<f64>),
+}
+
+impl Event<NestedInput> for NestedPointerAxisEvent {
+    fn time(&self) -> u64 {
+        self.time
+    }
+
+    fn device(&self) -> NestedVirtualDevice {
+        NestedVirtualDevice
+    }
+}
+
+impl PointerAxisEvent<NestedInput> for NestedPointerAxisEvent {
+    fn amount(&self, axis: Axis) -> Option<f64> {
+        match axis {
+            Axis::Horizontal => self.amount.0,
+            Axis::Vertical => self.amount.1,
+        }
+    }
+
+    fn amount_v120(&self, axis: Axis) -> Option<f64> {
+        match axis {
+            Axis::Horizontal => self.amount_v120.0,
+            Axis::Vertical => self.amount_v120.1,
+        }
+    }
+
+    fn source(&self) -> AxisSource {
+        self.source
+    }
+
+    fn relative_direction(&self, _axis: Axis) -> AxisRelativeDirection {
+        AxisRelativeDirection::Identical
+    }
+}
+
+/// Touch down event from the host wl_touch.
+#[derive(Debug, Clone, Copy, PartialEq)]
+pub struct NestedTouchDownEvent {
+    pub time: u64,
+    pub id: i32,
+    pub position: (f64, f64),
+    pub surface_size: (i32, i32),
+}
+
+impl Event<NestedInput> for NestedTouchDownEvent {
+    fn time(&self) -> u64 {
+        self.time
+    }
+
+    fn device(&self) -> NestedVirtualDevice {
+        NestedVirtualDevice
+    }
+}
+
+impl TouchDownEvent<NestedInput> for NestedTouchDownEvent {}
+impl TouchEvent<NestedInput> for NestedTouchDownEvent {
+    fn slot(&self) -> TouchSlot {
+        Some(self.id as u32).into()
+    }
+}
+impl AbsolutePositionEvent<NestedInput> for NestedTouchDownEvent {
+    fn x(&self) -> f64 {
+        self.position.0
+    }
+
+    fn y(&self) -> f64 {
+        self.position.1
+    }
+
+    fn x_transformed(&self, width: i32) -> f64 {
+        if self.surface_size.0 <= 0 {
+            return 0.0;
+        }
+        f64::max(self.position.0 * width as f64 / self.surface_size.0 as f64, 0.0)
+    }
+
+    fn y_transformed(&self, height: i32) -> f64 {
+        if self.surface_size.1 <= 0 {
+            return 0.0;
+        }
+        f64::max(self.position.1 * height as f64 / self.surface_size.1 as f64, 0.0)
+    }
+}
+
