new file mode 100644
index 0000000..8191997
--- /dev/null
+++ b/src/c_api.rs
@@ -0,0 +1,108 @@
+//! Wawona (wwn-niri): C ABI entry point for running niri in-process.
+//!
+//! On Apple mobile targets (and optionally Android), the Wawona app cannot
+//! fork/exec a bundled `niri` binary (App Store posture: no spawning external
+//! executables), so it links niri as a static library and starts the
+//! compositor on a dedicated thread through this entry point.
+//!
+//! Contract:
+//! - The host (Wawona) compositor socket must already be advertised through
+//!   WAYLAND_DISPLAY (and XDG_RUNTIME_DIR must point at a writable,
+//!   sandbox-safe directory inside the app container).
+//! - An explicit niri config may be passed through NIRI_CONFIG (read-only
+//!   bundled KDL); otherwise the built-in default config is used.
+//! - niri runs its nested backend (Wayland client of Wawona) and exports its
+//!   own child Wayland socket name through NIRI_NESTED_WAYLAND_DISPLAY so the
+//!   host app can point niri's clients at it.
+
+use std::env;
+use std::ffi::c_int;
+use std::path::PathBuf;
+
+use calloop::EventLoop;
+use smithay::reexports::wayland_server::Display;
+
+use crate::niri::State;
+
+/// Runs the niri compositor in-process until the session ends.
+///
+/// Returns 0 on clean shutdown and nonzero on a fatal startup error. Call at
+/// most once per process; niri's compositor state is not re-entrant.
+#[no_mangle]
+pub extern "C" fn niri_main() -> c_int {
+    match run() {
+        Ok(()) => 0,
+        Err(err) => {
+            // The host app may not have a tracing subscriber; make sure the
+            // failure reaches stderr either way.
+            eprintln!("niri_main: fatal error: {err:?}");
+            1
+        }
+    }
+}
+
+fn run() -> anyhow::Result<()> {
+    // The host app may already have installed a subscriber; ignore failure.
+    let directives = env::var("RUST_LOG")
+        .unwrap_or_else(|_| "niri=debug,smithay::backend::renderer::gles=error".to_owned());
+    let env_filter = tracing_subscriber::EnvFilter::builder().parse_lossy(directives);
+    let _ = tracing_subscriber::fmt()
+        .compact()
+        .with_writer(std::io::stderr)
+        .with_env_filter(env_filter)
+        .try_init();
+
+    tracy_client::Client::start();
+
+    info!("starting niri (in-process) version {}", crate::utils::version());
+
+    // Load the bundled/explicit config, falling back to the built-in default.
+    let config = match env::var_os("NIRI_CONFIG") {
+        Some(path) => {
+            let path = PathBuf::from(path);
+            match niri_config::Config::load(&path).config {
+                Ok(config) => config,
+                Err(err) => {
+                    warn!("error loading config from {path:?}: {err:?}; using the default config");
+                    niri_config::Config::load_default()
+                }
+            }
+        }
+        None => niri_config::Config::load_default(),
+    };
+
+    let mut event_loop = EventLoop::<State>::try_new()?;
+    let display = Display::new()?;
+
+    let mut state = State::new(
+        config,
+        event_loop.handle(),
+        event_loop.get_signal(),
+        display,
+        false,
+        true,
+        false,
+    )
+    .map_err(|err| anyhow::anyhow!("error creating the compositor state: {err}"))?;
+
+    // Export the child socket for the host app (niri's own clients connect
+    // to this, while niri itself stays connected to WAYLAND_DISPLAY).
+    if let Some(socket_name) = state.niri.socket_name.as_deref() {
+        env::set_var("NIRI_NESTED_WAYLAND_DISPLAY", socket_name);
+        info!(
+            "niri (nested) listening on Wayland socket: {}",
+            socket_name.to_string_lossy()
+        );
+    }
+
+    if let Some(ipc) = &state.niri.ipc_server {
+        if let Some(socket_path) = ipc.socket_path.as_deref() {
+            env::set_var(niri_ipc::socket::SOCKET_PATH_ENV, socket_path);
+            info!("IPC listening on: {}", socket_path.to_string_lossy());
+        }
+    }
+
+    event_loop.run(None, &mut state, |state| state.refresh_and_flush_clients())?;
+
+    Ok(())
+}
