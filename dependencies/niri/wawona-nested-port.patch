+
+impl Dispatch<WlSeat, ()> for State {
+    fn event(
+        state: &mut State,
+        proxy: &WlSeat,
+        event: wl_seat::Event,
+        _data: &(),
+        _conn: &Connection,
+        qh: &QueueHandle<State>,
+    ) {
+        if let wl_seat::Event::Capabilities { capabilities } = event {
+            let capabilities = match capabilities {
+                wayland_client::WEnum::Value(v) => v,
+                wayland_client::WEnum::Unknown(_) => return,
+            };
+            let nested = state.backend.nested();
+
+            if capabilities.contains(wl_seat::Capability::Pointer) {
+                if nested.host.pointer.is_none() {
+                    nested.host.pointer = Some(proxy.get_pointer(qh, ()));
+                }
+            } else if let Some(pointer) = nested.host.pointer.take() {
+                pointer.release();
+            }
+
+            if capabilities.contains(wl_seat::Capability::Keyboard) {
+                if nested.host.keyboard.is_none() {
+                    nested.host.keyboard = Some(proxy.get_keyboard(qh, ()));
+                }
+            } else if let Some(keyboard) = nested.host.keyboard.take() {
+                keyboard.release();
+            }
+
+            if capabilities.contains(wl_seat::Capability::Touch) {
+                if nested.host.touch.is_none() {
+                    nested.host.touch = Some(proxy.get_touch(qh, ()));
+                }
+            } else if let Some(touch) = nested.host.touch.take() {
+                touch.release();
+            }
+        }
+    }
+}
+
+impl Dispatch<WlPointer, ()> for State {
+    fn event(
+        state: &mut State,
+        _proxy: &WlPointer,
+        event: wl_pointer::Event,
+        _data: &(),
+        _conn: &Connection,
+        _qh: &QueueHandle<State>,
+    ) {
+        let surface_size = {
+            let nested = state.backend.nested();
+            (nested.window_size.w, nested.window_size.h)
+        };
+
+        match event {
+            wl_pointer::Event::Enter {
+                surface_x,
+                surface_y,
+                ..
+            }
+            | wl_pointer::Event::Motion {
+                surface_x,
+                surface_y,
+                ..
+            } => {
+                let time = match &event {
+                    wl_pointer::Event::Motion { time, .. } => u64::from(*time) * 1000,
+                    _ => get_monotonic_time().as_micros() as u64,
+                };
+                state.backend.nested().pointer_position = (surface_x, surface_y);
+                state.process_input_event(InputEvent::<NestedInput>::PointerMotionAbsolute {
+                    event: NestedPointerMotionEvent {
+                        time,
+                        position: (surface_x, surface_y),
+                        surface_size,
+                    },
+                });
+            }
+            wl_pointer::Event::Leave { .. } => (),
+            wl_pointer::Event::Button {
+                time,
+                button,
+                state: button_state,
+                ..
+            } => {
+                let button_state = match button_state {
+                    wayland_client::WEnum::Value(wl_pointer::ButtonState::Pressed) => {
+                        ButtonState::Pressed
+                    }
+                    wayland_client::WEnum::Value(wl_pointer::ButtonState::Released) => {
+                        ButtonState::Released
+                    }
+                    _ => return,
+                };
+                state.process_input_event(InputEvent::<NestedInput>::PointerButton {
+                    event: NestedPointerButtonEvent {
+                        time: u64::from(time) * 1000,
+                        button,
+                        state: button_state,
+                    },
+                });
+            }
+            wl_pointer::Event::Axis { time, axis, value } => {
+                let nested = state.backend.nested();
+                let pending = &mut nested.pending_axis;
+                pending.time = time;
+                pending.has_events = true;
+                match axis {
+                    wayland_client::WEnum::Value(wl_pointer::Axis::HorizontalScroll) => {
+                        pending.amount.0 = Some(pending.amount.0.unwrap_or(0.0) + value);
+                    }
+                    wayland_client::WEnum::Value(wl_pointer::Axis::VerticalScroll) => {
+                        pending.amount.1 = Some(pending.amount.1.unwrap_or(0.0) + value);
+                    }
+                    _ => (),
+                }
+            }
+            wl_pointer::Event::AxisSource { axis_source } => {
+                let source = match axis_source {
+                    wayland_client::WEnum::Value(wl_pointer::AxisSource::Wheel) => {
+                        AxisSource::Wheel
+                    }
+                    wayland_client::WEnum::Value(wl_pointer::AxisSource::Finger) => {
+                        AxisSource::Finger
+                    }
+                    wayland_client::WEnum::Value(wl_pointer::AxisSource::Continuous) => {
+                        AxisSource::Continuous
+                    }
+                    wayland_client::WEnum::Value(wl_pointer::AxisSource::WheelTilt) => {
+                        AxisSource::WheelTilt
+                    }
+                    _ => AxisSource::Continuous,
+                };
+                state.backend.nested().pending_axis.source = Some(source);
+            }
+            wl_pointer::Event::AxisDiscrete { axis, discrete } => {
+                let nested = state.backend.nested();
+                let pending = &mut nested.pending_axis;
+                pending.has_events = true;
+                match axis {
+                    wayland_client::WEnum::Value(wl_pointer::Axis::HorizontalScroll) => {
+                        pending.amount_v120.0 =
+                            Some(pending.amount_v120.0.unwrap_or(0.0) + f64::from(discrete) * 120.0);
+                    }
+                    wayland_client::WEnum::Value(wl_pointer::Axis::VerticalScroll) => {
+                        pending.amount_v120.1 =
+                            Some(pending.amount_v120.1.unwrap_or(0.0) + f64::from(discrete) * 120.0);
+                    }
+                    _ => (),
+                }
+            }
+            wl_pointer::Event::AxisValue120 { axis, value120 } => {
+                let nested = state.backend.nested();
+                let pending = &mut nested.pending_axis;
+                pending.has_events = true;
+                match axis {
+                    wayland_client::WEnum::Value(wl_pointer::Axis::HorizontalScroll) => {
+                        pending.amount_v120.0 =
+                            Some(pending.amount_v120.0.unwrap_or(0.0) + f64::from(value120));
+                    }
+                    wayland_client::WEnum::Value(wl_pointer::Axis::VerticalScroll) => {
+                        pending.amount_v120.1 =
+                            Some(pending.amount_v120.1.unwrap_or(0.0) + f64::from(value120));
+                    }
+                    _ => (),
+                }
+            }
+            wl_pointer::Event::Frame => {
+                let (axis, source, time) = {
+                    let nested = state.backend.nested();
+                    let pending = mem::take(&mut nested.pending_axis);
+                    if !pending.has_events {
+                        return;
+                    }
+                    (
+                        (pending.amount, pending.amount_v120),
+                        pending.source.unwrap_or(AxisSource::Wheel),
+                        pending.time,
+                    )
+                };
+                state.process_input_event(InputEvent::<NestedInput>::PointerAxis {
+                    event: NestedPointerAxisEvent {
+                        time: u64::from(time) * 1000,
+                        source,
+                        amount: axis.0,
+                        amount_v120: axis.1,
+                    },
+                });
+            }
+            _ => (),
+        }
+    }
+}
+
+impl Dispatch<WlKeyboard, ()> for State {
+    fn event(
+        state: &mut State,
+        _proxy: &WlKeyboard,
+        event: wl_keyboard::Event,
+        _data: &(),
+        _conn: &Connection,
+        _qh: &QueueHandle<State>,
+    ) {
+        match event {
+            wl_keyboard::Event::Key {
+                time,
+                key,
+                state: key_state,
+                ..
+            } => {
+                let key_state = match key_state {
+                    wayland_client::WEnum::Value(wl_keyboard::KeyState::Pressed) => {
+                        KeyState::Pressed
+                    }
+                    wayland_client::WEnum::Value(wl_keyboard::KeyState::Released) => {
+                        KeyState::Released
+                    }
+                    _ => return,
+                };
+                state.process_input_event(InputEvent::<NestedInput>::Keyboard {
+                    event: NestedKeyboardInputEvent {
+                        time: u64::from(time) * 1000,
+                        key,
+                        state: key_state,
+                    },
+                });
+            }
+            // niri runs its own XKB state on the raw keycodes; the host keymap
+            // and modifier events are intentionally ignored (same as the winit
+            // backend).
+            _ => (),
+        }
+    }
+}
+
+impl Dispatch<WlTouch, ()> for State {
+    fn event(
+        state: &mut State,
+        _proxy: &WlTouch,
+        event: wl_touch::Event,
+        _data: &(),
+        _conn: &Connection,
+        _qh: &QueueHandle<State>,
+    ) {
+        let surface_size = {
+            let nested = state.backend.nested();
+            (nested.window_size.w, nested.window_size.h)
+        };
+
+        match event {
+            wl_touch::Event::Down {
+                time, id, x, y, ..
+            } => {
+                state.process_input_event(InputEvent::<NestedInput>::TouchDown {
+                    event: NestedTouchDownEvent {
+                        time: u64::from(time) * 1000,
+                        id,
+                        position: (x, y),
+                        surface_size,
+                    },
+                });
+            }
+            wl_touch::Event::Motion { time, id, x, y } => {
+                state.process_input_event(InputEvent::<NestedInput>::TouchMotion {
+                    event: NestedTouchMotionEvent {
+                        time: u64::from(time) * 1000,
+                        id,
+                        position: (x, y),
+                        surface_size,
+                    },
+                });
+            }
+            wl_touch::Event::Up { time, id, .. } => {
+                state.process_input_event(InputEvent::<NestedInput>::TouchUp {
+                    event: NestedTouchUpEvent {
+                        time: u64::from(time) * 1000,
+                        id,
+                    },
+                });
+            }
+            wl_touch::Event::Cancel => {
+                state.process_input_event(InputEvent::<NestedInput>::TouchCancel {
+                    event: NestedTouchCancelEvent {
+                        time: get_monotonic_time().as_micros() as u64,
+                    },
+                });
+            }
+            _ => (),
+        }
+    }
+}
