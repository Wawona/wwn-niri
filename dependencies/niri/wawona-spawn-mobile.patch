+    // Apple mobile cannot fork/exec/posix_spawn. Route bundled helpers through
+    // Wawona's in-process dispatcher (same path as zsh exec on iOS).
+    #[cfg(any(target_os = "ios", target_os = "tvos", target_os = "visionos"))]
+    {
+        extern "C" {
+            fn wawona_dispatch_can_handle(argv0: *const libc::c_char) -> libc::c_int;
+            fn wawona_dispatch_inprocess(
+                path: *const libc::c_char,
+                argv: *const *const libc::c_char,
+                envp: *const *const libc::c_char,
+            ) -> libc::c_int;
+        }
+
+        let cmd_cstr = match CString::new(command.as_bytes()) {
+            Ok(s) => s,
+            Err(_) => return,
+        };
+        if unsafe { wawona_dispatch_can_handle(cmd_cstr.as_ptr()) } != 0 {
+            let mut argv_owned: Vec<CString> = Vec::new();
+            let mut argv_ptrs: Vec<*const libc::c_char> = Vec::new();
+
+            argv_owned.push(cmd_cstr);
+            argv_ptrs.push(argv_owned[0].as_ptr());
+            for arg in args {
+                match CString::new(arg.as_ref().as_bytes()) {
+                    Ok(s) => {
+                        argv_ptrs.push(s.as_ptr());
+                        argv_owned.push(s);
+                    }
+                    Err(_) => return,
+                }
+            }
+            argv_ptrs.push(std::ptr::null());
+
+            if REMOVE_ENV_RUST_BACKTRACE.load(Ordering::Relaxed) {
+                std::env::remove_var("RUST_BACKTRACE");
+            }
+            if REMOVE_ENV_RUST_LIB_BACKTRACE.load(Ordering::Relaxed) {
+                std::env::remove_var("RUST_LIB_BACKTRACE");
+            }
+            std::env::remove_var("NOTIFY_SOCKET");
+            let display = CHILD_DISPLAY.read().unwrap();
+            if let Some(display) = &*display {
+                std::env::set_var("DISPLAY", display);
+            } else {
+                std::env::remove_var("DISPLAY");
+            }
+            let env = CHILD_ENV.read().unwrap();
+            for var in &env.0 {
+                if let Some(value) = &var.value {
+                    std::env::set_var(&var.name, value);
+                } else {
+                    std::env::remove_var(&var.name);
+                }
+            }
+            drop(env);
+            if let Some(token) = token.as_ref() {
+                std::env::set_var("XDG_ACTIVATION_TOKEN", token.as_str());
+                std::env::set_var("DESKTOP_STARTUP_ID", token.as_str());
+            }
+
+            let rc = unsafe {
+                wawona_dispatch_inprocess(
+                    argv_owned[0].as_ptr(),
+                    argv_ptrs.as_ptr(),
+                    std::ptr::null(),
+                )
+            };
+            if rc >= 0 && rc != 0 {
+                warn!("in-process spawn of {:?} exited with {rc}", command);
+            }
+            return;
+        }
+    }
+
     let mut process = Command::new(command);
     process
         .args(args)
